{
  "name": "@skeptrune/telemetry-cli",
  "version": "1.0.0",
  "description": "Command-line client for the Telemetry body-recomposition API (browser SSO via Cloudflare Access, no API key).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skeptrunedev/telemetry.git",
    "directory": "packages/cli"
  },
  "homepage": "https://telemetry.skeptrune.com",
  "type": "commonjs",
  "bin": {
    "telemetry": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "binaries": "pkg dist/index.js --config package.json --out-path binaries",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^6.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "pkg": {
    "targets": [
      "node20-linux-x64",
      "node20-linux-arm64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-win-x64"
    ],
    "outputPath": "binaries"
  }
}
