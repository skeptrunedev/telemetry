{
  "name": "@skeptrune/skcal",
  "version": "0.1.0",
  "description": "Command-line client for the skcal calorie + body-composition API — built for developers and AI power users.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skeptrunedev/telemetry.git",
    "directory": "packages/cli"
  },
  "homepage": "https://app.skcal.fit",
  "type": "commonjs",
  "bin": {
    "skcal": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "binaries": "pkg dist/index.js -t host -o binaries/skcal",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@yao-pkg/pkg": "^6.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "pkg": {
    "outputPath": "binaries"
  }
}
