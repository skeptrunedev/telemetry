{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "skcal",
  "colors": {
    "primary": "#f59e0b",
    "light": "#fbbf24",
    "dark": "#d97706"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Integrate",
            "pages": ["mcp-server", "cli"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Endpoints",
            "openapi": "api-reference/openapi.json"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/skeptrunedev/telemetry"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open skcal",
      "href": "https://app.skcal.fit"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "mcp"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/skeptrunedev/telemetry"
    },
    "links": [
      {
        "header": "skcal",
        "items": [
          { "label": "App", "href": "https://app.skcal.fit" },
          { "label": "Privacy", "href": "https://app.skcal.fit/privacy" },
          { "label": "Terms", "href": "https://app.skcal.fit/terms" }
        ]
      }
    ]
  }
}
