# Always revalidate the entry points so a deploy is picked up immediately.
/index.html
  Cache-Control: no-cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
/registerSW.js
  Cache-Control: no-cache, no-store, must-revalidate
/manifest.webmanifest
  Cache-Control: no-cache

# Content-hashed build output never changes for a given URL — cache hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
