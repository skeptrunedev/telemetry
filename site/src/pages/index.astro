---
import Layout from "../layouts/Layout.astro";
import Check from "../components/Check.astro";

const APP = "https://app.skcal.fit";
---

<Layout>
  <nav class="wrap">
    <div class="nav-row">
      <a class="brand" href="/">skcal<span class="dot">.</span>fit</a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#pricing">Pricing</a>
        <a href="https://github.com/skeptrunedev/telemetry">GitHub</a>
        <a href={`${APP}/openapi.json`}>API</a>
      </div>
      <a class="btn" href={APP}>Get started</a>
    </div>
  </nav>

  <header class="hero">
    <div class="rings"><i class="r1"></i><i class="r2"></i></div>
    <div class="wrap hero-grid">
      <div>
        <h1>The calorie tracker built for <span class="hl">vibe coders</span>.</h1>
        <p class="hero-sub">
          Log meals from a chat with your agent, your terminal, or the app. Photo in, macros out —
          Claude does the counting, you keep shipping.
        </p>
        <div class="hero-ctas">
          <a class="btn" href="#connect">Connect MCP</a>
          <div class="codechip"><span class="p">$</span> npm i -g @skeptrune/skcal</div>
        </div>
        <p class="hero-note"># no app store. your tools already run it.</p>

        <div class="works">
          <h4>Works with</h4>
          <div class="works-row">
            <span>Claude</span>
            <span>Claude Code</span>
            <span>ChatGPT</span>
            <span>Cursor</span>
            <span>any MCP client</span>
          </div>
        </div>
      </div>
      <div class="phone">
        <img
          src="/landing/app-today.png"
          alt="skcal Today dashboard: weight trend, shoulder-to-waist ratio, measurements"
          width="390"
          height="800"
        />
      </div>
    </div>
  </header>

  <section class="dark">
    <div class="rings"><i class="r1"></i></div>
    <div class="wrap band">
      <div class="band-grid">
        <div class="phone">
          <img
            src="/landing/app-agent.png"
            alt="skcal agent moving a logged meal between days with tool calls"
            width="390"
            height="460"
          />
        </div>
        <div>
          <h2>Log it without leaving your flow.</h2>
          <p class="lead">skcal was built agent-first, so the fastest way to use it is to just say the thing.</p>
          <div class="feat">
            <div class="feat-item">
              <div class="ico">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h16v11H8l-4 4V5z"></path></svg>
              </div>
              <h3>An agent with real tools</h3>
              <p>
                “Move the beef jerky from today to yesterday.” The built-in agent reads your log, edits it, and
                answers with your real numbers — not vibes about vibes.
              </p>
            </div>
            <div class="feat-item">
              <div class="ico">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"></path><path d="M9 8V2"></path><path d="M15 8V2"></path><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8h12z"></path></svg>
              </div>
              <h3>MCP server, first-class</h3>
              <p>
                Connect Claude, ChatGPT, or Claude Code over OAuth 2.1 — no tokens to paste. Eight tools, scoped to
                your account: <code>skcal_get_status</code>, <code>skcal_log_meal</code>, <code>skcal_move_food</code>…
              </p>
            </div>
            <div class="feat-item">
              <div class="ico">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path><circle cx="12" cy="13" r="3"></circle></svg>
              </div>
              <h3>Photo → macros</h3>
              <p>
                Snap it, paste it, or describe it. Claude estimates calories + protein per item and logs the meal.
                Correct it in one sentence if it's off.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="grid-sec" id="features">
    <div class="wrap">
      <div class="sec-head">
        <h2>API-first, because you live in the terminal.</h2>
        <p>Every surface is programmable. The web app is just one client.</p>
      </div>
      <div class="cards">
        <div class="card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
          <h3>A real CLI</h3>
          <p>
            <code>skcal weight log 158.2</code>, <code>skcal meal describe "chipotle bowl"</code>,
            <code>skcal status</code>. npm install or standalone binaries.
          </p>
        </div>
        <div class="card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5c0 1.1.9 2 2 2h1"></path><path d="M16 21h1a2 2 0 0 0 2-2v-5c0-1.1.9-2 2-2a2 2 0 0 1-2-2V5a2 2 0 0 0-2-2h-1"></path></svg>
          <h3>Typed HTTP API</h3>
          <p>OpenAPI 3.1 with a lint-perfect spec. Every endpoint documented, every schema exact — pipe it straight into your codegen.</p>
        </div>
        <div class="card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
          <h3>Scoped API keys</h3>
          <p>
            Mint keys with fine-grained <code>resource:action</code> scopes — a read-only dashboard key, a write-only
            logger. Hashed at rest, revoke anytime.
          </p>
        </div>
        <div class="card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <h3>OAuth 2.1 everywhere</h3>
          <p>One sign-in guards the app, API, CLI, and MCP — PKCE, dynamic client registration, refresh tokens. No password, no shared secrets.</p>
        </div>
        <div class="card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8"></path><path d="M8.5 7L12 10.5 15.5 7"></path><rect x="3" y="14" width="18" height="8" rx="2"></rect><path d="M7 18h.01M11 18h.01"></path></svg>
          <h3>Scale ingest</h3>
          <p>Point your smart scale's webhook at one token-authed endpoint. Weigh-ins appear in your trend without opening anything.</p>
        </div>
        <div class="card">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path></svg>
          <h3>Your data, in the open</h3>
          <p>Weights in kg, measurements in cm, meals as line items — all pullable over the API. It's your database row, not our moat.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="dark" id="connect">
    <div class="cta wrap">
      <div class="rings"><i class="r1"></i></div>
      <h2>Start tracking today</h2>
      <p>
        Connect your agent or install the CLI in under a minute. Sign in once with Google or a magic link — OAuth
        handles the rest.
      </p>
      <div class="cta-blocks">
        <div class="codechip"><span class="c">mcp</span> https://app.skcal.fit/mcp</div>
        <div class="codechip"><span class="p">$</span> npm i -g @skeptrune/skcal</div>
      </div>
      <a class="btn" href={APP}>Get started</a>
    </div>
  </section>

  <section class="pricing" id="pricing">
    <div class="wrap">
      <div class="sec-head">
        <h2>One plan. Everything.</h2>
        <p>No free tier, no feature matrix, no “Pro”. $100 a month buys all of it.</p>
      </div>
      <div class="price-card">
        <div class="price-brand"><span class="mark">sk</span> skcal</div>
        <div class="price-num">$100<small>/mo</small></div>
        <p class="price-sub">Everything skcal does today — and everything it ships next.</p>
        <ul class="plist">
          <Check>Unlimited AI meal logging — photo, paste, or plain text</Check>
          <Check>The agent — chat, tools, saved &amp; searchable history</Check>
          <Check>MCP server access from any client</Check>
          <Check>CLI, typed API, and scoped API keys</Check>
          <Check>Weight, measurements, targets &amp; trend analytics</Check>
          <Check>Smart-scale ingest webhook</Check>
          <Check>Every new feature, the day it ships</Check>
        </ul>
        <a class="btn" href={APP}>Get started</a>
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap">
      <div class="foot-grid">
        <div>
          <a class="brand" href="/">skcal<span class="dot">.</span>fit</a>
          <p class="foot-tag">Calorie tracking for vibe coders.</p>
          <div class="foot-links">
            <a href={APP}>App</a>
            <a href="#features">Features</a>
            <a href="#pricing">Pricing</a>
            <a href="https://github.com/skeptrunedev/telemetry">GitHub</a>
            <a href={`${APP}/openapi.json`}>API</a>
            <a href={`${APP}/privacy`}>Privacy</a>
            <a href={`${APP}/terms`}>Terms</a>
          </div>
        </div>
        <div class="foot-connect">
          <h4>Connect your agent</h4>
          <p>Add skcal as a custom connector in Claude or ChatGPT, or one line in Claude Code:</p>
          <div class="codechip"><span class="p">$</span> claude mcp add --transport http skcal {APP}/mcp</div>
        </div>
      </div>
      <div class="copyright">
        <span>© 2026 skcal. All rights reserved.</span>
        <span>Built on Cloudflare Workers · Powered by Claude</span>
      </div>
    </div>
  </footer>
</Layout>
