---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import CodeChip from "../components/CodeChip.astro";
import CtaBand from "../components/CtaBand.astro";

const APP = "https://app.skcal.fit";
---

<Layout>
  <Nav />

  <header class="hero">
    <div class="rings"><i class="r1"></i><i class="r2"></i></div>
    <div class="wrap hero-grid">
      <div>
        <h1>Manage your fitness over <span class="hl">iMessage</span>.</h1>
        <p class="hero-sub">
          Text a picture of your food, send your measurements, share your weight, log your
          workouts — skcal tracks everything for you.
        </p>
        <div class="textme-static">
          <a class="btn textme-number" href="sms:+16283166355?&body=hi">Text +1 (628) 316-6355</a>
        </div>
        <p class="hero-note"># text anything to start — your food, weight, or just "hi". or <a href={APP}>start in the browser</a>.</p>
      </div>
      <div class="phone imsg-phone">
        <div
          class="imsg"
          role="img"
          aria-label="iMessage conversation: a photo of tacos is logged as 640 calories, a weigh-in of 158.2 is logged, and skcal replies with progress"
        >
          <div class="imsg-head">
            <span class="imsg-avatar">sk</span>
            <span class="imsg-name">skcal</span>
          </div>
          <div class="imsg-chat">
            <div class="b out att">📷 IMG_4211.heic</div>
            <div class="b out">lunch</div>
            <div class="b in">Logged: 2 carnitas tacos + rice — 640 cal, 31g protein. You're at 1,410 / 1,850 today.</div>
            <div class="b out">158.2 this morning</div>
            <div class="b in">Got it. Down 1.3 lb this week — right on pace.</div>
            <div class="b out">waist 31.8</div>
            <div class="b in">Logged. Shoulder-to-waist is 1.52, up from 1.49 last month.</div>
          </div>
        </div>
      </div>
    </div>
  </header>

  <section class="dark">
    <div class="rings"><i class="r1"></i></div>
    <div class="wrap band">
      <div class="band-grid">
        <div class="phone">
          <img
            src="/landing/app-today.png"
            alt="skcal web dashboard: weight trend, shoulder-to-waist ratio, measurements, and nutrition"
            width="390"
            height="800"
          />
        </div>
        <div>
          <h2>Fully customizable, when you want it.</h2>
          <p class="lead">
            Everything the agent does over text is an API you can call yourself. Wire skcal into
            Claude, your terminal, or your own scripts.
          </p>
          <div class="feat">
            <div class="feat-item">
              <div class="ico">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22v-5"></path><path d="M9 8V2"></path><path d="M15 8V2"></path><path d="M18 8v5a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4V8h12z"></path></svg>
              </div>
              <h3>MCP server, first-class</h3>
              <p>
                Connect Claude, ChatGPT, or Claude Code over OAuth 2.1 with no tokens to paste.
                Eight tools, scoped to your account: <code>skcal_get_status</code>,
                <code>skcal_log_meal</code>, <code>skcal_move_food</code>…
              </p>
            </div>
            <div class="feat-item">
              <div class="ico">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
              </div>
              <h3>A real CLI</h3>
              <p>
                Log weigh-ins, meals, and measurements from your shell. One install, browser or
                API-key sign-in:
              </p>
              <CodeChip cmd="npm i -g @skeptrune/skcal" class="chip-sm" />
            </div>
            <div class="feat-item">
              <div class="ico">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H7a2 2 0 0 0-2 2v5a2 2 0 0 1-2 2 2 2 0 0 1 2 2v5c0 1.1.9 2 2 2h1"></path><path d="M16 21h1a2 2 0 0 0 2-2v-5c0-1.1.9-2 2-2a2 2 0 0 1-2-2V5a2 2 0 0 0-2-2h-1"></path></svg>
              </div>
              <h3>Typed HTTP API</h3>
              <p>
                OpenAPI 3.1 behind every surface, with scoped bearer keys for scripts and a webhook
                endpoint for your smart scale. It's your data — pull it however you like.
              </p>
            </div>
          </div>
          <div class="works">
            <h4>Works with</h4>
            <div class="works-row">
              <span>iMessage</span>
              <span>Claude</span>
              <span>Claude Code</span>
              <span>ChatGPT</span>
              <span>Cursor</span>
              <span>any MCP client</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="teaser">
    <div class="wrap teaser-box">
      <div>
        <h2>One plan. Everything.</h2>
        <p>No free tier, no feature matrix. Every surface (iMessage, app, agent, MCP, CLI, API) in one price.</p>
      </div>
      <div class="teaser-actions">
        <span class="teaser-price">$100<small>/mo</small></span>
        <a class="btn" href={APP}>Get started</a>
        <a class="tlink" href="/pricing">See what's included</a>
      </div>
    </div>
  </section>

  <CtaBand />

  <Footer />
</Layout>

