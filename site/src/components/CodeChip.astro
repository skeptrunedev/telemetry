---
// A copyable command chip. `copy` is what lands on the clipboard (defaults to
// the visible command). `prefix` renders as a non-selectable shell/mcp marker.
interface Props {
  cmd: string;
  copy?: string;
  prefix?: string;
  class?: string;
}
const { cmd, copy = cmd, prefix = "$", class: klass = "" } = Astro.props;
---

<div class={`codechip ${klass}`}>
  <span class={prefix === "$" ? "p" : "c"}>{prefix}</span>
  <span class="cmd">{cmd}</span>
  <button class="chip-copy" type="button" data-copy={copy} aria-label={`Copy: ${copy}`}>
    <svg class="i-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <svg class="i-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
  </button>
</div>
