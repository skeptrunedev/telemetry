---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "skcal — the calorie tracker built for vibe coders",
  description = "Calorie + body-composition tracking you can drive from a chat, your terminal, or any agent. Photo in, macros out. MCP server, CLI, and typed API included.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://skcal.fit" />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%23f59e0b'/%3E%3Ctext x='16' y='21.5' font-family='monospace' font-size='14' font-weight='700' text-anchor='middle' fill='%231a1205'%3Esk%3C/text%3E%3C/svg%3E"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --amber: #f59e0b;
    --amber-deep: #d97706;
    --ink: #16181a;
    --ink-soft: #43464b;
    --muted: #6c6f73;
    --paper: #f7f7f5;
    --paper-2: #ededeb;
    --card: #ffffff;
    --card-line: #e5e5e2;
    --dark: #141517;
    --dark-2: #1c1d20;
    --dark-line: #2c2e31;
    --dark-fg: #ececec;
    --dark-muted: #9a9ca0;
    --mono: ui-monospace, "SF Mono", SFMono-Regular, Menlo, Consolas, monospace;
    --sans: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  * { box-sizing: border-box; margin: 0; }
  html { scroll-behavior: smooth; }
  body { font-family: var(--sans); color: var(--ink); background: var(--paper); line-height: 1.55; -webkit-font-smoothing: antialiased; }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }

  /* ---- buttons + code chips ---- */
  .btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--amber); color: #1a1205; font-weight: 650; font-size: 16px;
    padding: 12px 22px; border-radius: 12px; border: 0; cursor: pointer;
    transition: transform 120ms ease-out, background 160ms ease-out;
  }
  .btn:hover { background: #ffb224; }
  .btn:active { transform: scale(0.97); }
  .codechip {
    display: flex; align-items: center; gap: 10px;
    background: #17181a; color: #ececec; border: 1px solid #2c2e31;
    font-family: var(--mono); font-size: 14.5px;
    padding: 13px 18px; border-radius: 12px; white-space: nowrap; overflow-x: auto;
  }
  .codechip .p { color: var(--amber); user-select: none; }
  .codechip .c { color: #9a9ca0; user-select: none; }

  /* ---- nav ---- */
  nav { padding: 22px 0; }
  .nav-row { display: flex; align-items: center; gap: 36px; }
  .brand { font-family: var(--mono); font-weight: 700; letter-spacing: 0.16em; font-size: 17px; }
  .brand .dot { color: var(--amber); }
  .nav-links { display: flex; gap: 28px; font-size: 15.5px; color: var(--ink-soft); flex: 1; }
  .nav-links a:hover { color: var(--ink); }
  nav .btn { padding: 10px 18px; font-size: 15px; }
  @media (max-width: 720px) { .nav-links { display: none; } .nav-row { justify-content: space-between; } }

  /* ---- hero ---- */
  .hero { position: relative; overflow: hidden; padding: 64px 0 96px; }
  .hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 48px; align-items: center; position: relative; }
  h1 { font-size: clamp(38px, 5.2vw, 62px); line-height: 1.06; letter-spacing: -0.025em; font-weight: 750; }
  h1 .hl { color: var(--amber-deep); }
  .hero-sub { margin-top: 22px; font-size: 19px; color: var(--muted); max-width: 34em; }
  .hero-ctas { margin-top: 34px; display: flex; gap: 14px; flex-wrap: wrap; align-items: stretch; }
  .hero-note { margin-top: 14px; font-size: 13.5px; color: var(--muted); font-family: var(--mono); }
  .works { margin-top: 72px; }
  .works h4 { font-size: 14px; font-weight: 650; color: var(--ink-soft); margin-bottom: 18px; }
  .works-row { display: flex; gap: 14px 34px; flex-wrap: wrap; align-items: center; font-weight: 640; font-size: 17px; color: #9b9d9a; }

  /* phone frame */
  .phone {
    width: min(360px, 86vw); margin: 0 auto; position: relative; z-index: 1;
    border-radius: 46px; padding: 12px; background: #0d0e10;
    border: 1px solid #26282b;
    box-shadow: 0 40px 90px rgba(0, 0, 0, 0.35), 0 6px 18px rgba(0, 0, 0, 0.2);
  }
  .phone::before {
    content: ""; position: absolute; top: 24px; left: 50%; transform: translateX(-50%);
    width: 108px; height: 26px; border-radius: 14px; background: #0d0e10; z-index: 2;
  }
  .phone img { border-radius: 35px; width: 100%; }
  .rings { position: absolute; inset: 0; pointer-events: none; }
  .rings i { position: absolute; border: 1px solid rgba(0, 0, 0, 0.07); border-radius: 50%; }
  .dark .rings i { border-color: rgba(255, 255, 255, 0.06); }
  .rings .r1 { width: 720px; height: 720px; right: -160px; top: -80px; }
  .rings .r2 { width: 1040px; height: 1040px; right: -320px; top: -240px; }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero { padding-top: 40px; }
  }

  /* ---- dark feature band ---- */
  .dark { background: var(--dark); color: var(--dark-fg); position: relative; overflow: hidden; }
  .band { padding: 110px 0; }
  .band-grid { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 72px; align-items: center; }
  .band h2 { font-size: clamp(30px, 3.6vw, 44px); letter-spacing: -0.02em; line-height: 1.12; font-weight: 730; margin-bottom: 10px; }
  .band .lead { color: var(--dark-muted); font-size: 18px; margin-bottom: 8px; }
  .feat { margin-top: 42px; display: flex; flex-direction: column; gap: 40px; }
  .feat-item .ico {
    width: 44px; height: 44px; border-radius: 12px; display: grid; place-items: center;
    background: var(--dark-2); border: 1px solid var(--dark-line); margin-bottom: 16px;
  }
  .feat-item .ico svg { width: 21px; height: 21px; color: var(--amber); }
  .feat-item h3 { font-size: 20px; font-weight: 680; margin-bottom: 8px; }
  .feat-item p { color: var(--dark-muted); font-size: 16.5px; max-width: 36em; }
  .feat-item p code { font-family: var(--mono); font-size: 0.88em; background: rgba(255, 255, 255, 0.07); padding: 1px 6px; border-radius: 6px; }
  @media (max-width: 900px) { .band-grid { grid-template-columns: 1fr; } }

  /* ---- light feature grid ---- */
  .grid-sec { padding: 110px 0 120px; }
  .sec-head { text-align: center; max-width: 760px; margin: 0 auto 64px; }
  .sec-head h2 { font-size: clamp(30px, 3.8vw, 46px); letter-spacing: -0.02em; line-height: 1.12; font-weight: 730; }
  .sec-head p { margin-top: 16px; color: var(--muted); font-size: 18.5px; }
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .card { background: var(--card); border: 1px solid var(--card-line); border-radius: 22px; padding: 30px 28px; }
  .card svg { width: 24px; height: 24px; color: var(--ink); margin-bottom: 20px; }
  .card h3 { font-size: 18.5px; font-weight: 680; margin-bottom: 10px; }
  .card p { color: var(--muted); font-size: 16px; }
  .card p code { font-family: var(--mono); font-size: 0.85em; background: #f0f0ee; border: 1px solid var(--card-line); padding: 1px 6px; border-radius: 6px; }
  @media (max-width: 980px) { .cards { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) { .cards { grid-template-columns: 1fr; } }

  /* ---- dark CTA ---- */
  .cta { text-align: center; padding: 130px 0; position: relative; }
  .cta h2 { font-size: clamp(34px, 4.4vw, 54px); font-weight: 740; letter-spacing: -0.02em; }
  .cta p { color: var(--dark-muted); font-size: 19px; margin: 18px auto 40px; max-width: 34em; }
  .cta-blocks { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-bottom: 30px; }
  .cta-blocks .codechip { text-align: left; }
  .cta .rings .r1 { left: 50%; right: auto; transform: translateX(-50%); top: -140px; width: 860px; height: 860px; }

  /* ---- pricing ---- */
  .pricing { background: var(--paper-2); padding: 110px 0 120px; }
  .price-card {
    max-width: 560px; margin: 0 auto; background: var(--card);
    border: 1px solid var(--card-line); border-radius: 26px; padding: 40px 42px;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.06);
  }
  .price-brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-family: var(--mono); letter-spacing: 0.14em; }
  .price-brand .mark { width: 26px; height: 26px; border-radius: 7px; background: var(--amber); display: grid; place-items: center; color: #1a1205; font-size: 12px; letter-spacing: 0; }
  .price-num { font-size: 54px; font-weight: 760; letter-spacing: -0.03em; margin: 20px 0 4px; }
  .price-num small { font-size: 22px; font-weight: 600; color: var(--muted); letter-spacing: 0; }
  .price-sub { color: var(--muted); font-size: 16.5px; margin-bottom: 26px; }
  .plist { list-style: none; padding: 0; }
  .plist li { display: flex; align-items: center; gap: 12px; padding: 13px 2px; border-bottom: 1px solid #f0f0ee; font-size: 16px; }
  .plist li:last-child { border-bottom: 0; }
  .plist svg { width: 19px; height: 19px; color: var(--amber-deep); flex: none; }
  .price-card .btn { width: 100%; justify-content: center; margin-top: 26px; }

  /* ---- footer ---- */
  footer { padding: 74px 0 60px; }
  .foot-grid { display: flex; justify-content: space-between; gap: 40px; flex-wrap: wrap; }
  .foot-tag { color: var(--muted); margin-top: 8px; font-size: 15.5px; }
  .foot-links { display: flex; gap: 26px; flex-wrap: wrap; font-size: 15.5px; color: var(--ink-soft); margin-top: 26px; }
  .foot-links a:hover { color: var(--ink); }
  .foot-connect { max-width: 380px; }
  .foot-connect h4 { font-size: 16px; margin-bottom: 8px; }
  .foot-connect p { color: var(--muted); font-size: 14.5px; margin-bottom: 12px; }
  .foot-connect .codechip { font-size: 13px; padding: 10px 14px; }
  .copyright { margin-top: 56px; padding-top: 26px; border-top: 1px solid var(--card-line); color: var(--muted); font-size: 14.5px; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
</style>
