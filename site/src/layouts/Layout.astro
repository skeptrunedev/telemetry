---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "skcal — the calorie tracker built for vibe coders",
  description = "Calorie + body-composition tracking you can drive from a chat, your terminal, or any agent. Photo in, macros out. MCP server, CLI, and typed API included.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://skcal.fit" />
    <meta property="og:image" content="https://skcal.fit/og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <slot />
    <script is:inline>
      // Copy-to-clipboard for command chips. Swaps the copy icon for a check
      // for a beat; falls back silently if the clipboard API is unavailable.
      document.addEventListener("click", async (e) => {
        const btn = e.target.closest(".chip-copy");
        if (!btn) return;
        const text = btn.dataset.copy || "";
        let ok = false;
        try {
          await navigator.clipboard.writeText(text);
          ok = true;
        } catch {
          // Fallback for contexts where the async clipboard is unavailable.
          const ta = document.createElement("textarea");
          ta.value = text;
          ta.style.position = "fixed";
          ta.style.opacity = "0";
          document.body.appendChild(ta);
          ta.select();
          try { ok = document.execCommand("copy"); } catch { ok = false; }
          ta.remove();
        }
        if (ok) {
          btn.classList.add("copied");
          setTimeout(() => btn.classList.remove("copied"), 1400);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --amber: #f59e0b;
    --amber-deep: #b45309;
    --ink: #16181a;
    --ink-soft: #3f4247;
    --muted: #5d6065;
    --paper: #f7f7f5;
    --paper-2: #ededeb;
    --card: #ffffff;
    --card-line: #e2e2df;
    --dark: #141517;
    --dark-2: #1c1d20;
    --dark-line: #2c2e31;
    --dark-fg: #ececec;
    --dark-muted: #a3a5aa;
    --mono: ui-monospace, "SF Mono", SFMono-Regular, Menlo, Consolas, monospace;
    --sans: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --ease-out: cubic-bezier(0.23, 1, 0.32, 1);
  }
  * { box-sizing: border-box; margin: 0; }
  html { scroll-behavior: smooth; }
  html, body { overflow-x: clip; }
  body {
    font-family: var(--sans);
    color: var(--ink);
    background: var(--paper);
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; height: auto; }
  h1, h2, h3 { text-wrap: balance; }
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 24px); }

  /* ---- buttons ---- */
  .btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--amber); color: #1a1205; font-weight: 650; font-size: 16px;
    padding: 12px 22px; border-radius: 12px; border: 0; cursor: pointer;
    transition: transform 120ms var(--ease-out), background 160ms var(--ease-out);
  }
  .btn:hover { background: #ffb224; }
  .btn:active { transform: scale(0.97); }

  /* ---- code chips (copyable) ---- */
  .codechip {
    display: flex; align-items: center; gap: 10px;
    max-width: 100%; min-width: 0;
    background: #17181a; color: #ececec; border: 1px solid #2c2e31;
    font-family: var(--mono); font-size: 14.5px;
    padding: 11px 8px 11px 16px; border-radius: 12px;
  }
  .codechip .p { color: var(--amber); user-select: none; flex: none; }
  .codechip .c { color: #9a9ca0; user-select: none; flex: none; }
  .codechip .cmd { white-space: nowrap; overflow-x: auto; scrollbar-width: none; }
  .codechip .cmd::-webkit-scrollbar { display: none; }
  .chip-copy {
    flex: none; display: grid; place-items: center;
    width: 30px; height: 30px; border-radius: 8px; border: 0;
    background: transparent; color: #9a9ca0; cursor: pointer;
    transition: color 140ms var(--ease-out), background 140ms var(--ease-out);
  }
  .chip-copy:hover { color: #ececec; background: rgba(255, 255, 255, 0.08); }
  .chip-copy svg { width: 15px; height: 15px; }
  .chip-copy .i-check { display: none; }
  .chip-copy.copied .i-copy { display: none; }
  .chip-copy.copied .i-check { display: block; color: var(--amber); }
  .chip-sm { font-size: 13px; padding: 8px 6px 8px 13px; }

  /* ---- nav ---- */
  nav.wrap { padding-block: clamp(18px, 3.5vw, 26px); }
  .nav-row { display: flex; align-items: center; gap: clamp(16px, 3vw, 36px); }
  .brand { font-family: var(--mono); font-weight: 700; letter-spacing: 0.16em; font-size: 17px; display: inline-flex; align-items: center; gap: 9px; }
  .brand-mark { width: 30px; height: 30px; }
  .nav-links { display: flex; gap: clamp(16px, 2.6vw, 28px); font-size: 15.5px; color: var(--ink-soft); flex: 1; }
  .nav-links a:hover { color: var(--ink); }
  .nav-links a[aria-current="page"] { color: var(--ink); font-weight: 650; }
  .nav-cta { padding: 10px 18px; font-size: 15px; }
  .nav-burger {
    display: none; place-items: center; width: 42px; height: 42px;
    margin-left: auto; padding: 0; cursor: pointer;
    border: 1px solid var(--card-line); border-radius: 10px;
    background: var(--card); color: var(--ink);
    transition: transform 120ms var(--ease-out);
  }
  .nav-burger:active { transform: scale(0.95); }
  .nav-burger svg { width: 20px; height: 20px; }
  .nav-burger .i-x { display: none; }
  nav.open .nav-burger .i-bars { display: none; }
  nav.open .nav-burger .i-x { display: block; }
  .nav-menu { display: none; }
  @media (max-width: 720px) {
    nav.wrap { padding-block-start: max(28px, env(safe-area-inset-top)); }
    .nav-links, .nav-cta { display: none; }
    .nav-burger { display: grid; }
    nav.open .nav-menu {
      display: flex; flex-direction: column; gap: 2px;
      padding: 14px 4px 6px; font-size: 17px;
    }
    .nav-menu a { padding: 12px 10px; border-radius: 10px; color: var(--ink-soft); }
    .nav-menu a:active { background: var(--paper-2); }
    .nav-menu .btn { margin-top: 10px; justify-content: center; color: #1a1205; }
  }

  /* ---- hero ---- */
  .hero { position: relative; overflow: hidden; padding: clamp(48px, 8vw, 80px) 0 clamp(64px, 9vw, 96px); }
  .hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: clamp(40px, 5vw, 64px); align-items: center; position: relative; }
  h1 { font-size: clamp(36px, 5.2vw, 62px); line-height: 1.06; letter-spacing: -0.025em; font-weight: 750; }
  h1 .hl { color: var(--amber-deep); }
  .hero-sub { margin-top: 22px; font-size: clamp(17px, 2.2vw, 19px); color: var(--muted); max-width: 34em; }
  .hero-ctas { margin-top: 34px; display: flex; gap: 14px; flex-wrap: wrap; align-items: stretch; min-width: 0; }
  .hero-note { margin-top: 14px; font-size: 13px; color: var(--muted); font-family: var(--mono); }
  .hero-note a { text-decoration: underline; text-underline-offset: 3px; }
  .hero-note a:hover { color: var(--ink); }
  .textme { margin-top: 34px; display: flex; gap: 12px; flex-wrap: wrap; max-width: 460px; }
  .textme[hidden] { display: none; }
  .textme input {
    flex: 1 1 180px; min-width: 0; font: inherit; font-size: 16.5px;
    padding: 12px 16px; border-radius: 12px;
    border: 1px solid var(--card-line); background: var(--card); color: var(--ink);
    transition: border-color 140ms var(--ease-out), box-shadow 140ms var(--ease-out);
  }
  .textme input::placeholder { color: #75787d; }
  .textme input:focus { outline: none; border-color: var(--amber); box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.22); }
  .textme .btn:disabled { opacity: 0.65; cursor: default; }
  .textme-msg { margin-top: 16px; font-size: 15.5px; color: var(--ink-soft); max-width: 34em; }
  .textme-msg.ok { color: var(--ink); font-weight: 600; }
  .textme-static { margin-top: 34px; }
  .textme-number { font-family: var(--mono); font-size: clamp(17px, 4.6vw, 21px); padding: 16px 30px; }

  /* ---- iMessage conversation mock ---- */
  .imsg-phone { max-width: 390px; }
  .imsg {
    background: var(--card); border-radius: 35px; overflow: hidden;
    display: flex; flex-direction: column;
  }
  .imsg-head {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    padding: 20px 16px 12px; border-bottom: 1px solid var(--card-line);
  }
  .imsg-avatar {
    display: grid; place-items: center; width: 44px; height: 44px; border-radius: 50%;
    background: var(--amber); color: #1a1205;
    font-family: var(--mono); font-weight: 700; font-size: 15px;
  }
  .imsg-name { font-size: 12.5px; color: var(--muted); }
  .imsg-chat { display: flex; flex-direction: column; gap: 7px; padding: 18px 14px 24px; }
  .imsg .b {
    max-width: 82%; padding: 9px 14px; border-radius: 18px;
    font-size: 14.5px; line-height: 1.4;
  }
  .imsg .b.out { align-self: flex-end; background: #0a84ff; color: #fff; border-bottom-right-radius: 5px; }
  .imsg .b.in { align-self: flex-start; background: #e9e9eb; color: #111; border-bottom-left-radius: 5px; }
  .imsg .b.att { font-family: var(--mono); font-size: 13px; }
  .works { margin-top: clamp(48px, 7vw, 72px); }
  .works h4 { font-size: 14px; font-weight: 650; color: var(--ink-soft); margin-bottom: 16px; }
  .dark .works { margin-top: clamp(36px, 5vw, 48px); }
  .dark .works h4 { color: var(--dark-muted); }
  .works-row { display: flex; gap: 12px 28px; flex-wrap: wrap; align-items: center; font-weight: 640; font-size: clamp(15px, 2vw, 17px); color: #92948f; }

  /* phone frame */
  .phone {
    width: min(340px, 82vw); margin: 0 auto; position: relative; z-index: 1;
    border-radius: 46px; padding: 12px; background: #0d0e10;
    border: 1px solid #26282b;
    box-shadow: 0 32px 70px rgba(0, 0, 0, 0.3);
  }
  .phone::before {
    content: ""; position: absolute; top: 24px; left: 50%; transform: translateX(-50%);
    width: 104px; height: 25px; border-radius: 14px; background: #0d0e10; z-index: 2;
  }
  .phone img { border-radius: 35px; width: 100%; }
  .rings { position: absolute; inset: 0; pointer-events: none; }
  .rings i { position: absolute; border: 1px solid rgba(0, 0, 0, 0.07); border-radius: 50%; }
  .dark .rings i { border-color: rgba(255, 255, 255, 0.06); }
  .rings .r1 { width: 720px; height: 720px; right: -160px; top: -80px; }
  .rings .r2 { width: 1040px; height: 1040px; right: -320px; top: -240px; }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-grid .phone { margin-top: 8px; }
  }

  /* hero entrance: enhance-only (content is visible without it) */
  @media (prefers-reduced-motion: no-preference) {
    .hero-grid > div:first-child { animation: rise 640ms var(--ease-out) both; }
    .hero-grid .phone { animation: rise 640ms var(--ease-out) 120ms both; }
    @keyframes rise {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: none; }
    }
  }

  /* ---- page header (features / pricing) ---- */
  .page-head { padding-block: clamp(40px, 7vw, 84px) clamp(28px, 4vw, 44px); }
  .page-head h1 { font-size: clamp(34px, 4.6vw, 54px); }
  .page-head p { margin-top: 16px; color: var(--muted); font-size: clamp(17px, 2.2vw, 19px); max-width: 42em; }

  /* ---- dark feature band ---- */
  .dark { background: var(--dark); color: var(--dark-fg); position: relative; overflow: hidden; }
  .band { padding-block: clamp(72px, 10vw, 110px); }
  .band-grid { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: clamp(48px, 6vw, 72px); align-items: center; }
  .band h2 { font-size: clamp(30px, 3.6vw, 44px); letter-spacing: -0.02em; line-height: 1.12; font-weight: 730; margin-bottom: 10px; }
  .band .lead { color: var(--dark-muted); font-size: 18px; margin-bottom: 8px; }
  .feat { margin-top: 42px; display: flex; flex-direction: column; gap: clamp(28px, 4vw, 40px); }
  .feat-item .ico {
    width: 44px; height: 44px; border-radius: 12px; display: grid; place-items: center;
    background: var(--dark-2); border: 1px solid var(--dark-line); margin-bottom: 16px;
  }
  .feat-item .ico svg { width: 21px; height: 21px; color: var(--amber); }
  .feat-item h3 { font-size: 20px; font-weight: 680; margin-bottom: 8px; }
  .feat-item p { color: var(--dark-muted); font-size: 16.5px; max-width: 36em; }
  .feat-item p code { font-family: var(--mono); font-size: 0.88em; background: rgba(255, 255, 255, 0.07); padding: 1px 6px; border-radius: 6px; overflow-wrap: anywhere; }
  @media (max-width: 900px) { .band-grid { grid-template-columns: 1fr; } }

  /* ---- bento feature grid (features page) ---- */
  .bento { padding: clamp(20px, 3vw, 36px) 0 clamp(72px, 9vw, 110px); }
  .bento-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 20px; }
  .bcard {
    background: var(--card); border: 1px solid var(--card-line); border-radius: 22px;
    padding: clamp(24px, 3vw, 30px) clamp(22px, 3vw, 28px);
    grid-column: span 2; display: flex; flex-direction: column; gap: 10px;
  }
  .bcard.wide { grid-column: span 4; }
  .bcard.half { grid-column: span 3; }
  .bcard h3 { font-size: 18.5px; font-weight: 680; }
  .bcard > p { color: var(--muted); font-size: 16px; max-width: 52em; }
  .bcard p code { font-family: var(--mono); font-size: 0.85em; background: #f0f0ee; border: 1px solid var(--card-line); padding: 1px 6px; border-radius: 6px; overflow-wrap: anywhere; }
  .bcard .ico { width: 24px; height: 24px; color: var(--ink); margin-bottom: 8px; }
  .bcard .ico svg { width: 100%; height: 100%; }
  @media (max-width: 980px) {
    .bento-grid { grid-template-columns: 1fr 1fr; }
    .bcard, .bcard.wide, .bcard.half { grid-column: span 2; }
  }

  /* terminal mock */
  .term {
    margin-top: 8px; background: #141517; border: 1px solid #2c2e31; border-radius: 14px;
    font-family: var(--mono); font-size: 13.5px; line-height: 1.85; color: #d7d8da;
    padding: 14px 18px; overflow-x: auto;
  }
  .term .ps { color: var(--amber); }
  .term .ok { color: #86b97e; }
  .term .dim { color: #85878c; }

  /* scope chips */
  .scopes { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }
  .scopes span {
    font-family: var(--mono); font-size: 12.5px; padding: 4px 10px; border-radius: 999px;
    background: #f0f0ee; border: 1px solid var(--card-line); color: var(--ink-soft);
  }
  .scopes .on { background: rgba(245, 158, 11, 0.14); border-color: rgba(180, 83, 9, 0.35); color: var(--amber-deep); }

  /* surfaces table */
  .surfaces { padding: 0 0 clamp(72px, 9vw, 110px); }
  .surfaces h2 { font-size: clamp(26px, 3.2vw, 36px); letter-spacing: -0.02em; margin-bottom: 22px; }
  .surface-rows { border: 1px solid var(--card-line); border-radius: 18px; overflow: hidden; background: var(--card); }
  .srow { display: grid; grid-template-columns: 160px 1fr auto; gap: 18px; align-items: center; padding: 18px 22px; border-bottom: 1px solid var(--card-line); }
  .srow:last-child { border-bottom: 0; }
  .srow .sname { font-weight: 680; }
  .srow .sdesc { color: var(--muted); font-size: 15.5px; }
  .srow .shref { font-family: var(--mono); font-size: 13px; color: var(--amber-deep); white-space: nowrap; }
  .srow .shref:hover { text-decoration: underline; }
  @media (max-width: 720px) {
    .srow { grid-template-columns: 1fr; gap: 4px; }
    .srow .shref { justify-self: start; }
  }

  /* ---- dark CTA ---- */
  .cta { text-align: center; padding-block: clamp(84px, 11vw, 130px); position: relative; }
  .cta h2 { font-size: clamp(32px, 4.4vw, 54px); font-weight: 740; letter-spacing: -0.02em; }
  .cta p { color: var(--dark-muted); font-size: clamp(17px, 2.2vw, 19px); margin: 18px auto 36px; max-width: 34em; }
  .cta-blocks { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 30px; min-width: 0; }
  .cta-blocks .codechip { text-align: left; }
  .cta .rings .r1 { left: 50%; right: auto; transform: translateX(-50%); top: -140px; width: 860px; height: 860px; }

  /* ---- pricing ---- */
  .pricing { background: var(--paper-2); padding: clamp(64px, 9vw, 110px) 0 clamp(72px, 9vw, 120px); }
  .sec-head { text-align: center; max-width: 760px; margin: 0 auto clamp(40px, 6vw, 64px); }
  .sec-head h2 { font-size: clamp(30px, 3.8vw, 46px); letter-spacing: -0.02em; line-height: 1.12; font-weight: 730; }
  .sec-head p { margin-top: 16px; color: var(--muted); font-size: 18.5px; }
  .price-card {
    max-width: 560px; margin: 0 auto; background: var(--card);
    border: 1px solid var(--card-line); border-radius: 26px;
    padding: clamp(28px, 5vw, 40px) clamp(24px, 5vw, 42px);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.06);
  }
  .price-brand { display: flex; align-items: center; gap: 10px; font-weight: 700; font-family: var(--mono); letter-spacing: 0.14em; }
  .price-brand .mark { width: 26px; height: 26px; border-radius: 7px; background: var(--amber); display: grid; place-items: center; color: #1a1205; font-size: 12px; letter-spacing: 0; }
  .price-num { font-size: clamp(42px, 7vw, 54px); font-weight: 760; letter-spacing: -0.03em; margin: 20px 0 4px; }
  .price-num small { font-size: 22px; font-weight: 600; color: var(--muted); letter-spacing: 0; }
  .price-sub { color: var(--muted); font-size: 16.5px; margin-bottom: 26px; }
  .plist { list-style: none; padding: 0; }
  .plist li { display: flex; align-items: center; gap: 12px; padding: 13px 2px; border-bottom: 1px solid #f0f0ee; font-size: 16px; }
  .plist li:last-child { border-bottom: 0; }
  .plist svg { width: 19px; height: 19px; color: var(--amber-deep); flex: none; }
  .price-card .btn { width: 100%; margin-top: 26px; }

  /* pricing teaser (home) */
  .teaser { padding: clamp(64px, 9vw, 100px) 0; }
  .teaser-box {
    display: flex; align-items: center; justify-content: space-between; gap: 28px; flex-wrap: wrap;
    border: 1px solid var(--card-line); background: var(--card); border-radius: 22px;
    padding: clamp(24px, 4vw, 36px) clamp(22px, 4vw, 40px);
  }
  .teaser-box h2 { font-size: clamp(24px, 3vw, 32px); letter-spacing: -0.02em; }
  .teaser-box p { color: var(--muted); margin-top: 6px; max-width: 34em; }
  .teaser-price { font-size: clamp(30px, 4vw, 40px); font-weight: 750; letter-spacing: -0.02em; white-space: nowrap; }
  .teaser-price small { font-size: 0.5em; color: var(--muted); font-weight: 600; }
  .teaser-actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
  .tlink { font-weight: 650; color: var(--amber-deep); }
  .tlink:hover { text-decoration: underline; }

  /* FAQ */
  .faq { max-width: 680px; margin: clamp(48px, 7vw, 72px) auto 0; }
  .faq h2 { font-size: clamp(24px, 3vw, 32px); letter-spacing: -0.02em; margin-bottom: 18px; }
  .faq details { border-bottom: 1px solid var(--card-line); padding: 4px 0; }
  .faq summary { cursor: pointer; font-weight: 650; font-size: 16.5px; padding: 14px 0; list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 12px; }
  .faq summary::-webkit-details-marker { display: none; }
  .faq summary::after { content: "+"; font-weight: 500; color: var(--muted); font-size: 20px; transition: transform 180ms var(--ease-out); }
  .faq details[open] summary::after { transform: rotate(45deg); }
  .faq details p { color: var(--muted); font-size: 15.5px; padding: 0 0 16px; max-width: 60ch; }

  /* ---- footer ---- */
  footer { padding: clamp(52px, 7vw, 74px) 0 clamp(40px, 6vw, 60px); }
  .foot-grid { display: flex; justify-content: space-between; gap: 40px; flex-wrap: wrap; }
  .foot-tag { color: var(--muted); margin-top: 8px; font-size: 15.5px; }
  .foot-links { display: flex; gap: 14px 24px; flex-wrap: wrap; font-size: 15.5px; color: var(--ink-soft); margin-top: 26px; }
  .foot-links a:hover { color: var(--ink); }
  .foot-connect { max-width: 380px; min-width: 0; }
  .foot-connect h4 { font-size: 16px; margin-bottom: 8px; }
  .foot-connect p { color: var(--muted); font-size: 14.5px; margin-bottom: 12px; }
  .copyright { margin-top: clamp(36px, 6vw, 56px); padding-top: 26px; border-top: 1px solid var(--card-line); color: var(--muted); font-size: 14.5px; display: flex; justify-content: space-between; gap: 10px 16px; flex-wrap: wrap; }

  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after { animation: none !important; transition: none !important; }
  }
</style>
