{
  "expo": {
    "name": "skcal",
    "slug": "skcal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "fit.skcal.app",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "fit.skcal.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "skcal reads your weight and workouts from Apple Health so they are logged for you automatically — no manual entry.",
          "NSHealthUpdateUsageDescription": "skcal does not write to Apple Health yet. This permission is reserved for a future option to save your logged weigh-ins back to Health.",
          "background": false
        }
      ]
    ],
    "scheme": "skcal",
    "backgroundColor": "#141517",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#141517"
    },
    "extra": {
      "eas": {
        "projectId": "03af82f4-13a2-4717-9adb-9e51f4ce1718"
      }
    },
    "owner": "skeptrunes-team"
  }
}