{
  "name": "telemetry",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "openapi:gen": "node scripts/gen-openapi.mjs",
    "openapi:lint": "npx --yes @quobix/vacuum@0.27.0 lint --details --fail-severity info --min-score 100 src/worker/openapi.gen.json",
    "prebuild": "node scripts/gen-openapi.mjs",
    "build": "vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply telemetry-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply telemetry-db --remote"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.30.0",
    "esbuild": "^0.25.12",
    "miniflare": "^4.20260625.0",
    "swagger-jsdoc": "^6.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.0.0"
  }
}
